PORT=3000
CORS_ORIGIN=http://localhost:4200
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plotwise

# Optional overrides.
# - If DATABASE_URL is set, DB_HOST and DB_PORT can still override its host/port.
# - This is useful when you keep RDS credentials in DATABASE_URL but connect through an
#   SSM tunnel on 127.0.0.1:5432.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=plotwise

TYPEORM_SYNCHRONIZE=false
TYPEORM_MIGRATIONS_RUN=false
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true